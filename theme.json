{
  "schemaVersion": 1,
  "name": "NAVIS",
  "author": "takuya",
  "version": "0.8.0",
  "description": "NAVIS — Asuka-style ITコンサルタント、デスクで仕事するスリムチビ。14 states + sleep flow (yawn/doze/collapse) + animated reactions + 7 idle anims + workingTiers + jugglingTiers.",
  "viewBox": {
    "x": 0,
    "y": 0,
    "width": 32,
    "height": 32
  },
  "layout": {
    "contentBox": {
      "x": 8,
      "y": 4,
      "width": 16,
      "height": 26
    },
    "centerX": 16,
    "baselineY": 30,
    "visibleHeightRatio": 0.85,
    "baselineBottomRatio": 0.05
  },
  "eyeTracking": {
    "enabled": false,
    "states": [],
    "eyeRatioX": 0.5,
    "eyeRatioY": 0.434,
    "maxOffset": 4,
    "bodyScale": 0.25,
    "shadowStretch": 0.0,
    "shadowShift": 0.0,
    "trackingLayers": {
      "eyes": {
        "ids": [
          "eyes-js"
        ],
        "maxOffset": 4,
        "ease": 0.18
      },
      "body": {
        "ids": [
          "body-js"
        ],
        "maxOffset": 1,
        "ease": 0.12
      }
    }
  },
  "states": {
    "idle": [
      "navis-idle.gif"
    ],
    "thinking": [
      "navis-thinking.gif"
    ],
    "working": [
      "navis-working.gif"
    ],
    "juggling": [
      "navis-juggling.gif"
    ],
    "error": {
      "files": [
        "navis-error.gif"
      ],
      "fallbackTo": "attention"
    },
    "attention": [
      "navis-attention.gif"
    ],
    "notification": {
      "files": [
        "navis-notification.gif"
      ],
      "fallbackTo": "attention"
    },
    "sleeping": [
      "navis-sleeping.gif"
    ],
    "waking": [
      "navis-waking.gif"
    ],
    "carrying": {
      "files": [
        "navis-carrying.gif"
      ],
      "fallbackTo": "working"
    },
    "sweeping": {
      "files": [
        "navis-sweeping.gif"
      ],
      "fallbackTo": "working"
    },
    "yawning": {
      "files": [
        "navis-yawning.gif"
      ],
      "fallbackTo": "idle"
    },
    "dozing": {
      "files": [
        "navis-dozing.gif"
      ],
      "fallbackTo": "sleeping"
    },
    "collapsing": {
      "files": [
        "navis-collapsing.gif"
      ],
      "fallbackTo": "sleeping"
    }
  },
  "workingTiers": [
    {
      "minSessions": 3,
      "file": "navis-working-tier3.gif"
    },
    {
      "minSessions": 2,
      "file": "navis-juggling.gif"
    },
    {
      "minSessions": 1,
      "file": "navis-working.gif"
    }
  ],
  "idleAnimations": [
    {
      "file": "navis-idle-look-left.png",
      "duration": 4000
    },
    {
      "file": "navis-idle-look-right.png",
      "duration": 4000
    },
    {
      "file": "navis-idle-stretch.png",
      "duration": 5000
    },
    {
      "file": "navis-idle-yawn.png",
      "duration": 4500
    },
    {
      "file": "navis-idle-smug.png",
      "duration": 5000
    },
    {
      "file": "navis-idle-headphones-adjust.png",
      "duration": 4500
    },
    {
      "file": "navis-idle-hair-flip.png",
      "duration": 4000
    }
  ],
  "reactions": {
    "drag": {
      "file": "navis-react-drag.gif"
    },
    "clickLeft": {
      "file": "navis-react-click-left.gif",
      "duration": 2500
    },
    "clickRight": {
      "file": "navis-react-click-right.gif",
      "duration": 2500
    },
    "annoyed": {
      "file": "navis-react-annoyed.gif",
      "duration": 3500
    },
    "double": {
      "files": [
        "navis-react-double.gif"
      ],
      "duration": 3500
    }
  },
  "sleepSequence": {
    "mode": "phased",
    "phases": [
      {
        "state": "yawning",
        "duration": 4500
      },
      {
        "state": "dozing",
        "duration": 6000
      },
      {
        "state": "collapsing",
        "duration": 5000
      },
      {
        "state": "sleeping"
      }
    ]
  },
  "timings": {
    "minDisplay": {
      "attention": 2500,
      "error": 3500,
      "notification": 3500,
      "carrying": 2500,
      "sweeping": 5000,
      "working": 1000,
      "thinking": 1000
    },
    "autoReturn": {
      "attention": 5000,
      "error": 5000,
      "notification": 5000,
      "carrying": 3000
    },
    "yawnDuration": 4500,
    "dozeDuration": 6000,
    "collapseDuration": 5000,
    "wakeDuration": 3000,
    "deepSleepTimeout": 600000,
    "mouseIdleTimeout": 30000,
    "mouseSleepTimeout": 60000
  },
  "hitBoxes": {
    "default": {
      "x": 10,
      "y": 6,
      "w": 12,
      "h": 24
    },
    "sleeping": {
      "x": 9,
      "y": 12,
      "w": 14,
      "h": 18
    }
  },
  "sleepingHitboxFiles": [
    "navis-sleeping.gif"
  ],
  "jugglingTiers": [
    {
      "minSessions": 2,
      "file": "navis-working-tier3.gif"
    },
    {
      "minSessions": 1,
      "file": "navis-juggling.gif"
    }
  ]
}